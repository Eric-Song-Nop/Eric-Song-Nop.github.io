{
  "name": "ericoolen",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.2.1",
  "scripts": {
    "generate": "node scripts/generate-site.mjs",
    "site:install": "node scripts/install-generated-site.mjs",
    "build": "pnpm run generate && pnpm run site:install && pnpm --dir .gocire/site run build",
    "dev": "pnpm run generate && pnpm run site:install && pnpm --dir .gocire/site run dev -- --host 127.0.0.1",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "typescript-language-server": "5.3.0"
  },
  "files": [
    "blogs",
    "scripts",
    ".gocire.yml"
  ],
  "engines": {
    "node": ">=20.0"
  }
}
